OMNI_LOG_LEVEL=INFO
OMNI_METERED_APP_NAME=your-metered-app-name
OMNI_METERED_CREDENTIAL_API_KEY=your-metered-credential-api-key
OMNI_METERED_REGION=
OMNI_METERED_CACHE_TTL_SECONDS=300
OMNI_METERED_FETCH_TIMEOUT_SECONDS=5
OMNI_ICE_SERVERS_JSON=[
  {"urls":"stun:stun.relay.metered.ca:80"},
  {"urls":"turn:standard.relay.metered.ca:80","username":"your-username","credential":"your-password"},
  {"urls":"turn:standard.relay.metered.ca:80?transport=tcp","username":"your-username","credential":"your-password"},
  {"urls":"turn:standard.relay.metered.ca:443","username":"your-username","credential":"your-password"},
  {"urls":"turns:standard.relay.metered.ca:443?transport=tcp","username":"your-username","credential":"your-password"}
]
OMNI_USE_OPENRELAY=0
